# 앱 기본 설정
APP_ENV=development
SECRET_KEY=

# 데이터베이스
DATABASE_URL=sqlite:///wholesaler.db

# 관리자 초기 계정 (최초 1회 생성용)
ADMIN_INIT_USERNAME=
ADMIN_INIT_PASSWORD=

# 오너클랜 계정
OWNERCLAN_LOGIN_ID=
OWNERCLAN_LOGIN_PASSWORD=

# 철물박사 계정 (기업회원)
METALDIY_LOGIN_ID=
METALDIY_LOGIN_PASSWORD=

# DS도매 계정
DS1008_LOGIN_ID=
DS1008_LOGIN_PASSWORD=

# 자동 실행 설정 (새벽 3시 KST)
SCHEDULE_HOUR=3
SCHEDULE_MINUTE=0
DEFAULT_TIMEZONE=Asia/Seoul

# 텔레그램 알림
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 다운로드 저장 경로 (Railway: /tmp/downloads, 로컬: 원하는 경로)
DOWNLOADS_DIR=/tmp/downloads