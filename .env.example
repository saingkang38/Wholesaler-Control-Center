# 앱 기본 설정
APP_ENV=development
SECRET_KEY=

# 데이터베이스
DATABASE_URL=sqlite:///wholesaler.db

# 관리자 초기 계정 (최초 1회 생성용)
ADMIN_INIT_USERNAME=
ADMIN_INIT_PASSWORD=

# 오너클랜 계정
OWNERCLAN_LOGIN_ID=
OWNERCLAN_LOGIN_PASSWORD=

# 철물박사 계정 (기업회원)
METALDIY_LOGIN_ID=
METALDIY_LOGIN_PASSWORD=

# DS도매 계정
DS1008_LOGIN_ID=
DS1008_LOGIN_PASSWORD=

# 친구도매 API
CHINGUDOME_ID=
CHINGUDOME_API_KEY=
# 수집 모드: incremental(기본) / full_active / full_runout / daterange / single
CHINGUDOME_COLLECT_MODE=incremental

# 젠트레이드 API
ZENTRADE_ID=
ZENTRADE_API_KEY=
# 수집 모드: full_all(기본) / single / opendate
ZENTRADE_COLLECT_MODE=full_all

# 3MRO API (API URL: https://www.3mro.co.kr/shop/api_out.php)
MRO3_M_NO=
# 수집 모드: full_all(전체상품) / incremental(24시간 변동상품)
MRO3_COLLECT_MODE=full_all

# 자동 실행 설정 (새벽 3시 KST)
SCHEDULE_HOUR=3
SCHEDULE_MINUTE=0
DEFAULT_TIMEZONE=Asia/Seoul

# 텔레그램 알림
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 다운로드 저장 경로 (Railway: /tmp/downloads, 로컬: 원하는 경로)
DOWNLOADS_DIR=/tmp/downloads